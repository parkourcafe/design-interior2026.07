# ── Supabase ─────────────────────────────────────────────
# Project URL and anon key are public (used in the browser client).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM provider (продукт) ───────────────────────────────
# yandex | gigachat
LLM_PROVIDER=yandex
# YandexGPT: gpt://<folder>/yandexgpt-lite/latest | gpt://<folder>/yandexgpt/latest
# GigaChat:  GigaChat | GigaChat-Pro
LLM_MODEL=yandexgpt-lite

# Yandex Cloud Foundation Models
YC_FOLDER_ID=your-folder-id
YC_API_KEY=your-yc-api-key

# GigaChat (запасной провайдер) — заполняется при переключении
GIGACHAT_AUTH_KEY=

# ── App ──────────────────────────────────────────────────
# Base URL used to build public links (intake / proposal). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
