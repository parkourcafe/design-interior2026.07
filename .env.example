# ── Supabase ─────────────────────────────────────────────
# Project URL and publishable key are public (used in the browser client).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Legacy fallback for existing deployments. New deployments should use the key above.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM provider (продукт) ───────────────────────────────
# yandex | gigachat | zai
# ВНИМАНИЕ: 'zai' (Zhipu GLM, китайский провайдер) — отступление от guardrail
# CLAUDE.md, включён по явному решению владельца. Прод по умолчанию — yandex.
LLM_PROVIDER=yandex
# YandexGPT: yandexgpt-lite | yandexgpt   (или полный gpt://<folder>/<model>/latest)
# GigaChat:  GigaChat | GigaChat-Pro
# z.ai:      glm-4.6 | glm-4.5-air | glm-4.7-flash
LLM_MODEL=yandexgpt-lite

# Yandex Cloud Foundation Models
YC_FOLDER_ID=your-folder-id
YC_API_KEY=your-yc-api-key

# GigaChat (запасной провайдер) — заполняется при переключении
GIGACHAT_AUTH_KEY=

# z.ai / Zhipu GLM (опциональный провайдер, LLM_PROVIDER=zai)
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# ── App ──────────────────────────────────────────────────
# Base URL used to build public links (intake / proposal). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Канонический адрес сайта для SEO (robots, sitemap, canonical, OG). Без
# завершающего слэша. Пусто = фолбэк на NEXT_PUBLIC_APP_URL, затем апекс.
NEXT_PUBLIC_SITE_URL=https://arhidom.space

# Контакт поддержки: клиентский бриф (рядом с согласием на ПДн), футер
# лендинга и письма заявок на пилот. Убедитесь, что ящик реально принимает
# почту (иначе выставьте свой, например parkourcafe@gmail.com).
NEXT_PUBLIC_SUPPORT_EMAIL=support@arhidom.space

# Медиа лендинга. Пусто = CDN Higgsfield (по умолчанию). Чтобы хостить у себя:
#   npm run fetch:media   (скачает файлы в public/landing)
#   NEXT_PUBLIC_MEDIA_BASE=/landing
NEXT_PUBLIC_MEDIA_BASE=

# ── TWA / магазины приложений (Google Play + RuStore) ────
# Digital Asset Links для /.well-known/assetlinks.json (скрывает адресную
# строку в приложении). Заполнить ПОСЛЕ сборки AAB и получения отпечатков.
# Package name приложения, напр. space.arhidom.twa
ANDROID_PACKAGE_NAME=
# Отпечаток(и) SHA-256, через запятую. Нужны ОБА сертификата:
#   1) Google Play App Signing (Play Console → App integrity)
#   2) подпись RuStore (ваш upload keystore)
# Пример: AB:CD:...:EF, 12:34:...:90
ANDROID_CERT_SHA256=
